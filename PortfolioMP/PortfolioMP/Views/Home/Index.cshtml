@using Microsoft.AspNetCore.Builder
@using Microsoft.AspNetCore.Localization
@using Microsoft.Extensions.Options

@using PortfolioMP.Controllers
@using PortfolioMP.Models
@using Microsoft.AspNetCore.Mvc.Localization
@using Microsoft.Extensions.Localization

@* @model PortfolioMP.Models.ContactFormModel *@

@inject IViewLocalizer ViewLocalizer

@inject IOptions<RequestLocalizationOptions> LocOptions

@{
    string returnUrl = ViewContext.HttpContext.Request.Path;

    var requestCulture = Context.Features.Get<IRequestCultureFeature>();
    var cultureItems = LocOptions.Value.SupportedUICultures
        .Select(c => new SelectListItem { Value = c.Name, Text = c.DisplayName })
        .ToList();

}

<section id="page-top">
    <header>
        <nav class="navbar navbar-b navbar-trans navbar-expand-xl fixed-top" id="mainNav">
            <div class="container">
                <a class="navbar-brand js-scroll" href="#page-top">@ViewLocalizer["view.navbar.brand"]</a>
                <button class="navbar-toggler collapsed" type="button" data-toggle="collapse" data-target="#navbarDefault"
                        aria-controls="navbarDefault" aria-expanded="false" aria-label="Toggle navigation">
                    <span></span>
                    <span></span>
                    <span></span>
                </button>
                <div class="navbar-collapse collapse justify-content-end" id="navbarDefault">
                    <ul class="navbar-nav">
                        <li class="nav-item">
                            <a class="nav-link js-scroll active" href="#home" style="white-space: nowrap">@ViewLocalizer["view.navbar.home"]</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link js-scroll" href="#aboutMe" style="white-space: nowrap">@ViewLocalizer["view.navbar.aboutMe"]</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link js-scroll" href="#services">@ViewLocalizer["view.navbar.services"]</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link js-scroll" href="#experience">@ViewLocalizer["view.navbar.experience"]</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link js-scroll" href="#portfolio">@ViewLocalizer["view.navbar.portfolio"]</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link js-scroll" href="#contact">@ViewLocalizer["view.navbar.contact"]</a>
                        </li>

                        <li class="nav-item">
                            <!-- TODO:: add the flags displayed next to the names -->
                            <form asp-action="ChangeLanguage" asp-controller="Home" method="post" class="nav-link">

                                <input type="hidden" id="returnUrl" name="returnUrl" value="@returnUrl" />

                                <select id="culture"
                                        name="culture"
                                        class="form-control"
                                        onchange="this.form.submit();"
                                        asp-items="cultureItems"
                                        asp-for="@requestCulture.RequestCulture.UICulture.Name">
                                </select>

                            </form>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div id="home" class="intro route bg-image" style="background-image: url(images/intro-bg.jpg)">
        <div class="overlay-intro"></div>
        <div class="intro-content display-table">
            <div class="table-cell">
                <div class="container">
                    <p class="display-6 color-d"> @ViewLocalizer["view.intro.hello"] </p>
                    <h1 class="intro-title mb-4"> @ViewLocalizer["view.intro.iam"] </h1>
                    <p class="intro-subtitle"><span class="text-slider-items">@ViewLocalizer["view.intro.webdev"],@ViewLocalizer["view.intro.backenddev"],@ViewLocalizer["view.intro.juniorcsharp"],@ViewLocalizer["view.intro.juniorjava"],@ViewLocalizer["view.intro.juniorpython"]</span><strong class="text-slider"></strong></p>
                    <p class="pt-3">
                        <a class="btn px-4 js-scroll" href="#contact" role="button">@ViewLocalizer["view.navbar.contact"]</a>
                        <a class="btn px-4" href="https://github.com/MichalPamieta/SGGW-PotI-My_Third_Website_final_project" role="button">@ViewLocalizer["view.intro.downloadCode"]</a>
                        <!--<a class="btn px-4" href="~/code.zip" download="Pamięta_Michał_196099.zip" role="button">@ViewLocalizer["view.intro.downloadCode"]</a>-->
                        <a class="btn px-4" href="~/Pamięta_Michał_CV.zip" download="Pamięta_Michał_CV.zip" role="button">@ViewLocalizer["view.intro.downloadCv"]</a>
                    </p>
                </div>
            </div>
        </div>

        <div class="cookie-banner" style="display: none">
            @ViewLocalizer["view.cookies.banner"]
            <button class="close">&times;</button>
        </div>

    </div>

